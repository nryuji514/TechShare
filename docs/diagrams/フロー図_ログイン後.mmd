---
config:
  layout: elk
  theme: base
  themeVariables:
    fontFamily: "Segoe UI, Meiryo, sans-serif"
    fontSize: "16px"
    lineColor: "#7a7a7a"
  flowchart:
    curve: linear
---
flowchart TD
    Login([ログイン成功]) --> Home["ホーム<br/>最新の投稿5件"]

    Home --> Create["新規投稿"]
    Home --> List["記事一覧<br/>検索・タグ絞り込み・並び替え"]
    Home --> Mypage["マイページ<br/>自分の投稿一覧"]
    Home --> Logout([ログイン画面へ])

    Create -->|投稿後| List
    List --> Detail["記事詳細<br/>いいね・コメント"]
    Detail -->|本人なら編集| Edit["投稿編集"]
    Edit -->|保存| Detail

    Mypage -->|編集| Edit
    Mypage -->|削除（確認後）| Mypage
    Mypage --> Profile["プロフィール編集<br/>アイコン変更"]
    Profile -->|保存| Mypage

    classDef startNode fill:#ECEFF1,stroke:#546E7A,stroke-width:2px,color:#263238;
    classDef home fill:#D1E7DD,stroke:#0F5132,stroke-width:2px,color:#0F5132;
    classDef article fill:#CFE2FF,stroke:#084298,stroke-width:1.5px,color:#084298;
    classDef mypage fill:#F8D7DA,stroke:#842029,stroke-width:1.5px,color:#842029;

    class Login,Logout startNode;
    class Home home;
    class Create,List,Detail,Edit article;
    class Mypage,Profile mypage;
